{
  "name": "energy-attestation-service",
  "version": "0.0.1",
  "description": "On-chain energy attestation service built on top of EAS",
  "type": "module",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "lint": "npm run lint:sol && npm run lint:ts",
    "lint:sol": "solhint 'contracts/**/*.sol'",
    "lint:ts": "eslint scripts test",
    "deploy:amoy": "hardhat run scripts/deploy.ts --network amoy",
    "deploy:polygon": "hardhat run scripts/deploy.ts --network polygon",
    "deploy:celo": "hardhat run scripts/deploy.ts --network celo",
    "seed:amoy": "hardhat run scripts/seed.ts --network amoy",
    "verify:amoy": "hardhat verify --network amoy",
    "verify:polygon": "hardhat verify --network polygon",
    "verify:celo": "hardhat verify --network celo",
    "copy-abi": "cp artifacts/contracts/EnergyRegistry.sol/EnergyRegistry.json subgraph/abis/EnergyRegistry.json"
  },
  "keywords": [
    "ethereum",
    "eas",
    "attestation",
    "energy",
    "web3",
    "sdk",
    "EVM"
  ],
  "author": "Suno",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.3",
    "@nomicfoundation/hardhat-verify": "^3.0.12",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.15",
    "chai": "^6.2.2",
    "eslint": "^10.1.0",
    "ethers": "^6.16.0",
    "hardhat": "^3.2.0",
    "mocha": "^11.7.5",
    "mocha-junit-reporter": "^2.2.1",
    "solhint": "^6.1.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  },
  "dependencies": {
    "@ethereum-attestation-service/eas-contracts": "^1.8.0",
    "@openzeppelin/contracts": "^5.6.1",
    "dotenv": "^17.3.1"
  },
  "overrides": {
    "diff": "8.0.4",
    "serialize-javascript": "7.0.5"
  }
}
